#include <stdio.h>

int main() {
    int pages[] = {1,2,3,1,4,5};
    int frames[3], i, j, n = 6, f = 3;
    int index = 0, fault = 0;

    // Initialize frames
    for(i=0;i<f;i++)
        frames[i] = -1;

    for(i=0;i<n;i++) {
        int found = 0;

        // Check if page already exists
        for(j=0;j<f;j++) {
            if(frames[j] == pages[i]) {
                found = 1;
                break;
            }
        }

        // If not found → replace
        if(!found) {
            frames[index] = pages[i];
            index = (index + 1) % f;
            fault++;
        }
    }

    printf("Total Page Faults = %d", fault);

    return 0;
}
