#include <stdio.h>

int state[5]; // 0=thinking, 1=hungry, 2=eating

void test(int i) {
    if(state[i] == 1 &&
       state[(i+4)%5] != 2 &&
       state[(i+1)%5] != 2) {

        state[i] = 2;
        printf("Philosopher %d is Eating\n", i);
    }
}

void take_fork(int i) {
    state[i] = 1;
    printf("Philosopher %d is Hungry\n", i);

    test(i);
}

void put_fork(int i) {
    state[i] = 0;
    printf("Philosopher %d is Thinking\n", i);

    test((i+4)%5); // left neighbor
    test((i+1)%5); // right neighbor
}

int main() {
    int i;

    for(i=0;i<5;i++)
        state[i] = 0;

    for(i=0;i<5;i++) {
        take_fork(i);
        put_fork(i);
    }

    return 0;
}
