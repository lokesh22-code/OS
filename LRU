#include <stdio.h>

int main() {
    int pages[] = {1,2,3,1,4,5};   // reference string
    int frames[3], time[3];        // frames and time arrays
    int i, j, n = 6, f = 3;
    int fault = 0, t = 0;

    // Initialize frames and time
    for(i = 0; i < f; i++) {
        frames[i] = -1;
        time[i] = 0;
    }

    // Process each page
    for(i = 0; i < n; i++) {
        int found = 0;

        // Check if page is already present
        for(j = 0; j < f; j++) {
            if(frames[j] == pages[i]) {
                found = 1;
                time[j] = ++t;   // update recent use
                break;
            }
        }

        // If page not found → replace LRU
        if(!found) {
            int pos = 0;

            // Find least recently used page
            for(j = 1; j < f; j++) {
                if(time[j] < time[pos])
                    pos = j;
            }

            frames[pos] = pages[i];   // replace page
            time[pos] = ++t;          // update time
            fault++;                  // increase fault count
        }

        // Print frames after each step (optional for understanding)
        printf("\nAfter page %d: ", pages[i]);
        for(j = 0; j < f; j++) {
            if(frames[j] != -1)
                printf("%d ", frames[j]);
            else
                printf("- ");
        }
    }

    printf("\n\nTotal Page Faults = %d\n", fault);

    return 0;
}
